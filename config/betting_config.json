{
  "_comment": "Kalshi Edge — multi-system betting config",

  "bankroll_usd": 10.0,
  "min_spend_usd": 1.0,
  "max_single_bet_usd": 5.0,

  "systems": {
    "crypto_15min": {
      "enabled": true,
      "interval_seconds": 900,
      "max_daily_usd": 4.00,
      "min_edge": 0.04,
      "kelly_fraction": 0.10
    },
    "research_daily": {
      "enabled": true,
      "interval_minutes": 60,
      "max_daily_usd": 6.00,
      "min_edge": 0.05,
      "min_confidence": 0.50,
      "kelly_fraction": 0.10
    }
  },

  "categories": {
    "crypto": {
      "max_daily_usd": 3.00,
      "min_edge": 0.04,
      "min_confidence": 0.45
    },
    "econ": {
      "max_daily_usd": 2.00,
      "min_edge": 0.06,
      "min_confidence": 0.55
    },
    "political": {
      "max_daily_usd": 1.00,
      "min_edge": 0.08,
      "min_confidence": 0.60
    },
    "weather": {
      "max_daily_usd": 1.00,
      "min_edge": 0.07,
      "min_confidence": 0.55
    },
    "sports": {
      "max_daily_usd": 2.00,
      "min_edge": 0.05,
      "min_confidence": 0.50
    },
    "misc": {
      "max_daily_usd": 0.50,
      "min_edge": 0.08,
      "min_confidence": 0.60
    }
  },

  "global_limits": {
    "max_bets_per_cycle": 5,
    "max_open_bets": 20,
    "max_total_exposure_usd": 8.00,
    "max_exposure_pct_of_bankroll": 0.80
  },

  "edge_thresholds": {
    "tier1_elite": 0.15,
    "tier2_strong": 0.10,
    "tier3_moderate": 0.06,
    "tier4_marginal": 0.03
  },

  "strategy_weights": {
    "CryptoMomentumStrategy":     1.0,
    "CryptoVolMispricingStrategy": 1.0,
    "TimedecayExploitStrategy":   1.2,
    "MeanReversionFadeStrategy":  0.8,
    "OpenInterestSignalStrategy": 1.1,
    "CrossTimeframeArbStrategy":  1.0,
    "EconConsensusStrategy":      1.3,
    "FedWatchArbStrategy":        1.3,
    "PollingArbStrategy":         0.7,
    "WeatherForecastStrategy":    1.0,
    "CalendarEffectStrategy":     0.9,
    "VolumeBreakoutStrategy":     1.0
  },

  "research": {
    "auto_settle_on_cycle": true,
    "deep_analysis_interval_hours": 6,
    "consensus_refresh_hours": 12,
    "snapshot_top_n": 25,
    "report_path": "db/research_report.json",
    "econ_consensus_cache": "db/econ_consensus.json"
  },

  "logging": {
    "log_dir": "logs",
    "research_log_prefix": "research",
    "systems_log": "logs/all_systems.log",
    "level": "INFO"
  }
}
