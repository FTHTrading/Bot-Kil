# ─────────────────────────────────────────────────────────────
# KALISHI EDGE — Environment Variables
# Copy to .env and fill in your keys
# ─────────────────────────────────────────────────────────────

# ── The Odds API (https://the-odds-api.com) ──────────────────
# Free tier: 500 requests/month — upgrade for live + more sports
ODDS_API_KEY=YOUR_ODDS_API_KEY_HERE

# ── Sportradar (Optional — premium data) ─────────────────────
SPORTRADAR_KEY=

# ── OpenAI (for AI analysis overlay) ─────────────────────────
OPENAI_API_KEY=

# ── Kalshi API (prediction markets) ──────────────────────────
KALSHI_API_KEY=
KALSHI_API_SECRET=
KALSHI_ENV=production   # or demo

# ── DraftKings / FanDuel (account tracking only) ─────────────
# No direct API — scraping is used for line comparison
SPORTSBOOK_TRACKING=true

# ── Bankroll Settings ─────────────────────────────────────────
BANKROLL_TOTAL=10000
KELLY_FRACTION=0.25        # Quarter Kelly (conservative)
MAX_BET_PCT=0.05           # Max 5% per bet
MIN_EDGE_PCT=0.03          # Min 3% edge to place

# ── Sports Coverage ───────────────────────────────────────────
SPORTS=americanfootball_nfl,basketball_nba,baseball_mlb,icehockey_nhl,soccer_epl

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./db/kalishi_edge.db

# ── Server ────────────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8420
DASHBOARD_PORT=3420
# ── Cloudflare (for Pages deploy + Tunnel) ───────────────────
CLOUDFLARE_API_TOKEN=          # Edit Cloudflare Workers token
CLOUDFLARE_DNS_TOKEN=          # Edit zone DNS token  
CLOUDFLARE_ACCOUNT_ID=07bcc4a189ef176261b818409c95891f
CLOUDFLARE_ZONE_ID=98ca5b0b945ae77292e6b7755ab7c3be   # drunks.app
CF_PAGES_PROJECT=kalishi-edge-dashboard

# ── Production URLs ──────────────────────────────────────────
NEXT_PUBLIC_MCP_API_URL=https://api.bet.drunks.app
DASHBOARD_URL=https://bet.drunks.app